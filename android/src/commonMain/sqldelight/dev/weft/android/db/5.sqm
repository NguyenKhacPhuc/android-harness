-- Migration 5 → 6.
--
-- Adds per-agent attribution to `usage_daily`. The composite PK
-- changes from `(day)` to `(day, agent_name)`, so the standard
-- SQLite copy-rename rebuild dance is required (ALTER TABLE can add
-- columns but not change PRIMARY KEY).
--
-- Existing rows back-fill to 'default' — matching the pre-multi-agent
-- assumption that all usage belonged to the auto-default agent. New
-- rows from multi-agent hosts will carry their AgentDeclaration's
-- name so per-agent cost breakdowns become queryable.
--
-- Day-level rollup queries (selectAll, selectLifetimeTotals) keep
-- their semantics via SUM + GROUP BY day; per-agent queries are
-- additive.
--
-- Defensive CREATE TABLE IF NOT EXISTS per MIGRATIONS.md so devices
-- that landed without the original usage_daily get the new shape
-- directly.

CREATE TABLE IF NOT EXISTS usage_daily_new (
    day TEXT NOT NULL,
    agent_name TEXT NOT NULL DEFAULT 'default',
    usd_total REAL NOT NULL DEFAULT 0,
    input_tokens INTEGER NOT NULL DEFAULT 0,
    output_tokens INTEGER NOT NULL DEFAULT 0,
    cache_read_tokens INTEGER NOT NULL DEFAULT 0,
    cache_write_tokens INTEGER NOT NULL DEFAULT 0,
    PRIMARY KEY (day, agent_name)
);

INSERT INTO usage_daily_new(day, agent_name, usd_total, input_tokens, output_tokens, cache_read_tokens, cache_write_tokens)
SELECT day, 'default', usd_total, input_tokens, output_tokens, cache_read_tokens, cache_write_tokens
FROM usage_daily;

DROP TABLE usage_daily;
ALTER TABLE usage_daily_new RENAME TO usage_daily;

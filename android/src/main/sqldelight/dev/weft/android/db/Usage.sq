-- Per-day usage aggregates. Lifetime totals are computed by SUM over all
-- days at read time — cheap because there's one row per day and apps
-- live for months, not centuries.
--
-- "day" is a LocalDate.toString() (ISO-8601 "yyyy-MM-dd"), in the device's
-- default time zone. We do not store time zone — same as the in-memory
-- store; midnight rollover is whatever the device thinks "today" is.
--
-- Last-call ephemeral state (lastCallUsd / lastCallTokens / lastCallModelId
-- in UsageTotals) intentionally stays in-memory: it's a transient UI signal
-- ("this call cost $X") that doesn't need to survive restart.

CREATE TABLE usage_daily (
    day TEXT NOT NULL PRIMARY KEY,
    usd_total REAL NOT NULL DEFAULT 0,
    input_tokens INTEGER NOT NULL DEFAULT 0,
    output_tokens INTEGER NOT NULL DEFAULT 0,
    cache_read_tokens INTEGER NOT NULL DEFAULT 0,
    cache_write_tokens INTEGER NOT NULL DEFAULT 0
);

selectAll:
SELECT day, usd_total, input_tokens, output_tokens, cache_read_tokens, cache_write_tokens
FROM usage_daily
ORDER BY day DESC;

selectDay:
SELECT day, usd_total, input_tokens, output_tokens, cache_read_tokens, cache_write_tokens
FROM usage_daily
WHERE day = ?;

selectLifetimeTotals:
SELECT COALESCE(SUM(usd_total), 0.0) AS lifetime_usd,
       COALESCE(SUM(input_tokens), 0) AS lifetime_input,
       COALESCE(SUM(output_tokens), 0) AS lifetime_output,
       COALESCE(SUM(cache_read_tokens), 0) AS lifetime_cache_read,
       COALESCE(SUM(cache_write_tokens), 0) AS lifetime_cache_write
FROM usage_daily;

-- Atomic add: insert-or-add. SQLDelight 2.x supports ON CONFLICT DO UPDATE.
addToDay:
INSERT INTO usage_daily(day, usd_total, input_tokens, output_tokens, cache_read_tokens, cache_write_tokens)
VALUES (:day, :usd, :inputTokens, :outputTokens, :cacheReadTokens, :cacheWriteTokens)
ON CONFLICT(day) DO UPDATE SET
    usd_total = usd_total + excluded.usd_total,
    input_tokens = input_tokens + excluded.input_tokens,
    output_tokens = output_tokens + excluded.output_tokens,
    cache_read_tokens = cache_read_tokens + excluded.cache_read_tokens,
    cache_write_tokens = cache_write_tokens + excluded.cache_write_tokens;

deleteAll:
DELETE FROM usage_daily;
